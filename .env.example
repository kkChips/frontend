# Frontend environment variables (copy to .env and fill in real values)
# Vite requires VITE_ prefix for client-side exposed variables

# GLM / DeepSeek API（前端直连，离线降级用）
VITE_GLM_API_KEY=your_glm_api_key_here
VITE_GLM_MODEL=deepseek-chat
VITE_GLM_BASE_URL=https://api.deepseek.com

# Backend API base URL
# Zeabur 部署时留空，让 nginx 反向代理处理（前端用相对路径 /api/v1/...）
# 如果前端独立部署（如 Cloudflare Pages），填 backend 公网域名：
# VITE_API_BASE_URL=https://backend.xxx.zeabur.app

# AI Tutor 服务 URL（视频生成用）
# Zeabur 部署时留空，让 nginx 反向代理处理（前端用相对路径 /api/v1/video/...）
# 如果前端独立部署，填 ai-tutor 公网域名：
# VITE_AI_TUTOR_URL=https://ai-tutor.xxx.zeabur.app
